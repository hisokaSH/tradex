# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your_secret_here

# Discord OAuth app — create at https://discord.com/developers/applications
# Set redirect URI to: http://localhost:3000/api/auth/callback/discord
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# ─── Discord Bot (for role checking) ──────────────────────────────────────────
# Bot token from your Discord application — needs SERVER MEMBERS INTENT
DISCORD_BOT_TOKEN=your_bot_token_here

# Your Discord server (guild) ID — right-click server → Copy Server ID
DISCORD_GUILD_ID=your_guild_id_here

# ─── News Feed ────────────────────────────────────────────────────────────────
# Free tier at https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=your_cryptopanic_key

# ─── Exchange APIs (added per user in settings) ───────────────────────────────
# These will be stored per-user in your DB, not as env vars
# BINANCE_API_KEY=
# BINANCE_SECRET=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
